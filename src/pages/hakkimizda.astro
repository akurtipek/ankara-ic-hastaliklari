<!DOCTYPE html>
<html lang="tr">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Ankara İç Hastalıkları Araştırma ve Geliştirme Derneği</title>

  <link rel="stylesheet" href="/style.css">
</head>

<body>

  <!-- HEADER -->
  <div id="header"></div>

  <!-- SAYFA İÇERİĞİ -->
  <main>

    <section style="padding:40px;">
      <h2>Derneğimiz</h2>

      <p>
        Ankara Üniversitesi Tıp Fakültesi, İç Hastalıkları Anabilim Dalı öğretim üyeleri tarafından kurulmuş,
        bilimsel ve sosyal faaliyetleri destekleyen sivil toplum kuruluşudur.
      </p>
    </section>

  </main>

  <!-- FOOTER -->
  <div id="footer"></div>

  <!-- SCRIPT -->
  <script>
    fetch("/components/header.html")
      .then(res => res.text())
      .then(data => {
        document.getElementById("header").innerHTML = data;
      });

    fetch("/components/footer.html")
      .then(res => res.text())
      .then(data => {
        document.getElementById("footer").innerHTML = data;
      });
  </script>

</body>
</html>
