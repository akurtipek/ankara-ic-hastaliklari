---
import duyurular from "../../data/duyurular.json";

export function getStaticPaths() {
  return duyurular.map((d) => ({
    params: { slug: d.slug },
  }));
}

const { slug } = Astro.params;

const duyuru = duyurular.find(d => d.slug === slug);
---


<html lang="tr">
  <head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="/style.css">
    <title>{duyuru?.baslik}</title>
  </head>

  <body>

    <div id="header"></div>

    <main class="container">
      <h1>{duyuru?.baslik}</h1>
      <p>{duyuru?.aciklama}</p>

      {duyuru?.pdf && (
        <iframe
          src={duyuru.pdf}
          width="100%"
          height="800px"
        />
      )}
    </main>

    <div id="footer"></div>

    <script>
      fetch("/components/header.html")
        .then(r => r.text())
        .then(d => document.getElementById("header").innerHTML = d);

      fetch("/components/footer.html")
        .then(r => r.text())
        .then(d => document.getElementById("footer").innerHTML = d);
    </script>

  </body>
</html>
