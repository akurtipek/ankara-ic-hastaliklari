---
import duyurular from "../../data/duyurular.json";

const { slug } = Astro.params;

const duyuru = duyurular.find(d => d.slug === slug);
---

<html>
  <head>
    <link rel="stylesheet" href="/style.css">
  </head>

  <body>

    <div id="header"></div>

    <main>
      <h1>{duyuru.baslik}</h1>
      <p>{duyuru.aciklama}</p>

      {duyuru.pdf && (
        <div style="margin-top:30px;">
          
          <!-- PDF GÖSTER -->
          <iframe
            src={duyuru.pdf}
            width="100%"
            height="800px"
            style="border:1px solid #ddd; border-radius:8px;"
          />

          <!-- Alternatif link -->
          <p>
            <a href={duyuru.pdf} target="_blank">
              📄 PDF’yi yeni sekmede aç
            </a>
          </p>

        </div>
      )}

    </main>

    <div id="footer"></div>

    <script>
      fetch("/components/header.html")
        .then(r => r.text())
        .then(d => document.getElementById("header").innerHTML = d);

      fetch("/components/footer.html")
        .then(r => r.text())
        .then(d => document.getElementById("footer").innerHTML = d);
    </script>

  </body>
</html>
